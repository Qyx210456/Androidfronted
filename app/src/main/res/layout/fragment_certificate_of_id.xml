<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/lightest_blue">

    <!--顶部导航栏 - 使用Material Toolbar并适配状态栏-->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/top_leading"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#FF458FFC"
        android:elevation="4dp"
        app:layout_constraintTop_toTopOf="parent"
        app:titleTextColor="@color/white"
        app:titleCentered="true">

        <!--返回按钮-->
        <ImageView
            android:id="@+id/apply_btn_back"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="start|center_vertical"
            android:layout_marginStart="16dp"
            android:src="@drawable/ic_arrow_back_white"
            android:contentDescription="@string/nav_back" />

        <!--页面标题，实名认证-->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="@string/id_info"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end"/>

    </com.google.android.material.appbar.MaterialToolbar>

    <!-- 未认证状态容器 -->
    <LinearLayout
        android:id="@+id/container_not_certified"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="32dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/top_leading"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- 身份证图标 -->
        <ImageView
            android:id="@+id/iv_id_card_icon"
            android:layout_width="170dp"
            android:layout_height="150dp"
            android:layout_marginTop="60dp"
            android:layout_marginBottom="24dp"
            android:src="@drawable/no_bank_card"
            tools:src="@drawable/no_bank_card" />

        <!-- 暂未认证身份证标题 -->
        <TextView
            android:id="@+id/tv_no_id_card_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/no_info_id"
            android:textColor="@color/text_secondary"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btn_id_upload"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="50dp"
            android:background="@drawable/bg_gradient_blue_horizontal"
            app:backgroundTint="@null"
            android:text="@string/upload_id"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- 上传中状态容器 -->
    <ScrollView
        android:id="@+id/container_uploading"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/top_leading"
        app:layout_constraintBottom_toTopOf="@id/btn_confirm_id_submission"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="32dp"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <!--身份证正面上传button-->
            <LinearLayout
                android:id="@+id/front_ID"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_product_info_card"
                android:clipToPadding="false"
                android:elevation="2dp"
                android:orientation="vertical"
                android:padding="16dp"
                android:gravity="center_horizontal">

                <ImageView
                    android:id="@+id/iv_id_front"
                    android:layout_width="match_parent"
                    android:layout_height="180dp"
                    android:background="@drawable/id_card_front"
                    android:scaleType="centerCrop"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/upload_the_face_of_your_ID_card"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/number_amount"
                    android:layout_marginTop="8dp"/>

            </LinearLayout>

            <!--身份证反面上传button-->
            <LinearLayout
                android:id="@+id/back_ID"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_product_info_card"
                android:clipToPadding="false"
                android:elevation="2dp"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:layout_marginTop="16dp"
                android:padding="16dp">

                <ImageView
                    android:id="@+id/iv_id_back"
                    android:layout_width="match_parent"
                    android:layout_height="180dp"
                    android:background="@drawable/id_card_back"
                    android:scaleType="centerCrop"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/upload_the_back_of_your_ID_card"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/number_amount"
                    android:layout_marginTop="8dp"/>

            </LinearLayout>

            <!--信息输入板块-->
            <LinearLayout
                android:id="@+id/enter_id"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_id_card"
                android:clipToPadding="false"
                android:elevation="2dp"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:layout_marginTop="16dp"
                android:padding="16dp">

                <!--姓名输入框-->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingVertical="8dp">

                    <TextView
                        android:layout_width="80dp"
                        android:layout_height="wrap_content"
                        android:text="@string/your_name"
                        android:textColor="@color/text_secondary"
                        android:textStyle="bold"
                        android:textSize="15sp"
                        android:gravity="start"/>

                    <EditText
                        android:id="@+id/et_name"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:paddingStart="16dp"
                        android:background="@null"
                        android:textSize="15sp"
                        android:hint="@string/enter_your_name"
                        android:inputType="textPersonName"
                        android:maxLength="20"/>
                </LinearLayout>

                <!--分隔线-->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/color_e7e9eb" />

                <!--身份证号输入框-->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingVertical="8dp">

                    <TextView
                        android:layout_width="80dp"
                        android:layout_height="wrap_content"
                        android:text="@string/ID_number"
                        android:textColor="@color/text_secondary"
                        android:textStyle="bold"
                        android:textSize="15sp"
                        android:gravity="start"/>

                    <EditText
                        android:id="@+id/et_id_number"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:paddingStart="16dp"
                        android:background="@null"
                        android:textSize="15sp"
                        android:hint="@string/enter_your_ID_card"
                        android:inputType="number"
                        android:maxLength="18"/>
                </LinearLayout>

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- "确认上传"按钮（固定底部） -->
    <Button
        android:id="@+id/btn_confirm_id_submission"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginHorizontal="32dp"
        android:layout_marginBottom="32dp"
        android:layout_marginTop="16dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        android:background="@drawable/bg_gradient_blue_horizontal"
        app:backgroundTint="@null"
        android:text="@string/conform_submission"
        android:textColor="@color/white"
        android:textSize="16sp"
        android:textStyle="bold" />

    <!-- 已认证状态容器 -->
    <LinearLayout
        android:id="@+id/container_certified"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/top_leading"
        app:layout_constraintBottom_toTopOf="@id/btn_modify_id">

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="16dp"
            android:background="@color/white"
            app:cardCornerRadius="8dp"
            app:cardElevation="4dp">

            <!-- 认证信息内容 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- 姓名 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">
                    <TextView
                        android:layout_width="80dp"
                        android:layout_height="wrap_content"
                        android:text="姓名："
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp" />
                    <TextView
                        android:id="@+id/tv_name"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text=""
                        android:textColor="@color/text_primary"
                        android:textSize="14sp" />
                </LinearLayout>

                <!-- 身份证号 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">
                    <TextView
                        android:layout_width="80dp"
                        android:layout_height="wrap_content"
                        android:text="身份证号："
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp" />
                    <TextView
                        android:id="@+id/tv_id_number"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text=""
                        android:textColor="@color/text_primary"
                        android:textSize="14sp" />
                </LinearLayout>

                <!-- 身份证正面 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="12dp">
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="身份证正面："
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp"
                        android:layout_marginBottom="8dp" />
                    <ImageView
                        android:id="@+id/iv_id_front_display"
                        android:layout_width="match_parent"
                        android:layout_height="200dp"
                        android:background="@drawable/bg_id_card"
                        android:scaleType="centerCrop"
                        tools:src="@drawable/ic_launcher_background" />
                </LinearLayout>

                <!-- 身份证反面 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="8dp">
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="身份证反面："
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp"
                        android:layout_marginBottom="8dp" />
                    <ImageView
                        android:id="@+id/iv_id_back_display"
                        android:layout_width="match_parent"
                        android:layout_height="200dp"
                        android:background="@drawable/bg_id_card"
                        android:scaleType="centerCrop"
                        tools:src="@drawable/ic_launcher_background" />
                </LinearLayout>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

    </LinearLayout>

    <!-- 修改实名认证按钮 -->
    <Button
        android:id="@+id/btn_modify_id"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginHorizontal="32dp"
        android:layout_marginBottom="32dp"
        android:layout_marginTop="16dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        android:background="@drawable/bg_gradient_blue_horizontal"
        app:backgroundTint="@null"
        android:text="修改实名认证"
        android:textColor="@color/white"
        android:textSize="16sp"
        android:textStyle="bold" />

</androidx.constraintlayout.widget.ConstraintLayout>
