<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/lightest_blue">

    <!--顶部导航栏 - 使用Material Toolbar并适配状态栏-->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/top_leading"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#FF458FFC"
        android:elevation="4dp"
        app:layout_constraintTop_toTopOf="parent"
        app:titleTextColor="@color/white"
        app:titleCentered="true">

        <!--返回按钮-->
        <ImageView
            android:id="@+id/apply_btn_back"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="start|center_vertical"
            android:layout_marginStart="16dp"
            android:src="@drawable/ic_arrow_back_white"
            android:contentDescription="@string/nav_back" />

        <!--页面标题，我的银行卡-->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="@string/menu_my_bank_card"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end"/>

    </com.google.android.material.appbar.MaterialToolbar>

    <!-- 未认证状态容器 -->
    <LinearLayout
        android:id="@+id/container_not_certified"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="32dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/top_leading"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- 银行卡图标 -->
        <ImageView
            android:id="@+id/iv_bank_card_icon"
            android:layout_width="170dp"
            android:layout_height="150dp"
            android:layout_marginTop="60dp"
            android:layout_marginBottom="24dp"
            android:src="@drawable/no_bank_card"
            tools:src="@drawable/no_bank_card" />

        <!-- 暂未认证银行卡标题 -->
        <TextView
            android:id="@+id/tv_no_bank_card_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/no_info_bank_card"
            android:textColor="@color/text_secondary"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnGoToInfoBankcard"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="50dp"
            android:background="@drawable/bg_gradient_blue_horizontal"
            app:backgroundTint="@null"
            android:text="@string/goto_info_bank_card"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- 上传中状态容器 -->
    <ScrollView
        android:id="@+id/container_uploading"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/top_leading"
        app:layout_constraintBottom_toTopOf="@id/btn_confirm_bank_card_upload"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="32dp"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <LinearLayout
                android:id="@+id/enter_bank_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_id_card"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingVertical="8dp">

                    <TextView
                        android:layout_width="80dp"
                        android:layout_height="wrap_content"
                        android:text="@string/bank_card_number"
                        android:textStyle="bold"
                        android:textColor="@color/text_secondary"
                        android:textSize="15sp"
                        android:gravity="start"/>

                    <EditText
                        android:id="@+id/et_bank_card_number"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:hint="@string/enter_bank_card_number"
                        android:textColorHint="@color/gray_dark_73"
                        android:textSize="15sp"
                        android:fontFamily="sans-serif"
                        android:background="@null"
                        android:paddingStart="16dp"
                        android:inputType="number"
                        android:maxLength="19"/>

                </LinearLayout>

                <!--分隔线-->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/color_e7e9eb" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingVertical="8dp">

                    <TextView
                        android:layout_width="80dp"
                        android:layout_height="wrap_content"
                        android:text="@string/bank_name"
                        android:textStyle="bold"
                        android:textColor="@color/text_secondary"
                        android:textSize="15sp"
                        android:gravity="start"/>

                    <EditText
                        android:id="@+id/et_bank_name"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:hint="@string/enter_bank_name"
                        android:textColorHint="@color/gray_dark_73"
                        android:textSize="15sp"
                        android:fontFamily="sans-serif"
                        android:background="@null"
                        android:paddingStart="16dp"
                        android:inputType="text"
                        android:maxLength="50"/>

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- "确认提交"按钮（固定底部） -->
    <Button
        android:id="@+id/btn_confirm_bank_card_upload"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginHorizontal="32dp"
        android:layout_marginBottom="32dp"
        android:layout_marginTop="16dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        android:background="@drawable/bg_gradient_blue_horizontal"
        app:backgroundTint="@null"
        android:text="@string/conform_submission"
        android:textColor="@color/white"
        android:textSize="16sp"
        android:textStyle="bold" />

    <!-- 已认证状态容器 -->
    <LinearLayout
        android:id="@+id/container_certified"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/top_leading"
        app:layout_constraintBottom_toTopOf="@id/btn_add_bank_card">

        <!-- 筛选和删除按钮行 -->
        <LinearLayout
            android:id="@+id/ll_filter_row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="16dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- 筛选组件 -->
            <LinearLayout
                android:id="@+id/ll_filter"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:background="@drawable/bg_id_card"
                android:padding="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="筛选："
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp"
                    android:layout_marginEnd="8dp"
                    android:gravity="center_vertical"/>

                <Spinner
                    android:id="@+id/spinner_filter"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:background="@null"
                    android:hint="请选择银行"/>

            </LinearLayout>

            <!-- 删除按钮 -->
            <Button
                android:id="@+id/btn_delete"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:paddingHorizontal="16dp"
                android:background="@drawable/bg_gradient_blue_horizontal"
                app:backgroundTint="@null"
                android:text="管理"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:layout_marginStart="16dp"/>

        </LinearLayout>

        <!-- 已上传银行卡列表 -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_bank_cards"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="16dp"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
            tools:listitem="@layout/item_bank_card" />

    </LinearLayout>

    <!-- 添加银行卡按钮 -->
    <Button
        android:id="@+id/btn_add_bank_card"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginHorizontal="32dp"
        android:layout_marginBottom="32dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        android:background="@drawable/bg_gradient_blue_horizontal"
        app:backgroundTint="@null"
        android:text="添加银行卡"
        android:textColor="@color/white"
        android:textSize="16sp"
        android:textStyle="bold" />

</androidx.constraintlayout.widget.ConstraintLayout>
