<?xml version="1.0" encoding="utf-8"?>
 <androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF8FAFF">
    <!--NestedScrollView布局确保内容可滚动-->

    <!-- 首页内容区域-->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp">

            <!-- 使用LinearLayout包裹ImageView和TextView，并将其居中 -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_centerInParent="true"
                android:layout_gravity="center">

                <!-- Logo 图标 -->
                <ImageView
                    android:id="@+id/ivLogo"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_app_logo"
                    android:contentDescription="Logo"/>

                <!-- 应用名称 -->
                <TextView
                    android:id="@+id/tvAppName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="贷款助手"
                    android:textColor="@color/primary_blue_100"
                    android:textSize="20sp"
                    android:textStyle="bold"/>
            </LinearLayout>

        </RelativeLayout>

        <!-- 2. 系统公告行 -->
        <RelativeLayout
            android:id="@+id/layoutSystemNotice"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="0dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/bg_notification_rounded"
            android:clickable="true"
            android:focusable="true">

            <!-- 喇叭图标 -->
            <ImageView
                android:id="@+id/ivNoticeIcon"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_centerVertical="true"
                android:layout_marginStart="12dp"
                android:src="@drawable/ic_home_speaker"
                app:tint="@color/primary_blue_100"/>

            <!-- 公告文本 -->
            <TextView
                android:id="@+id/tvSystemNotice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:layout_toEndOf="@id/ivNoticeIcon"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="12dp"
                android:text="最新利率下调2.5%，点击查看详情 >"
                android:textColor="@color/primary_blue_100"
                android:textSize="14sp"
                android:ellipsize="marquee"
                android:singleLine="true"
                android:marqueeRepeatLimit="marquee_forever"
                android:focusable="true"
                android:focusableInTouchMode="true"/>

        </RelativeLayout>

        <!-- 3. 广告位轮播 -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:layout_marginBottom="16dp">

            <!-- 静态广告图片 -->
            <ImageView
                android:id="@+id/ivAdImage"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="fitXY"
                android:src="@drawable/bg_home_advertisement"/>

            <!-- 广告标签 -->
            <TextView
                android:layout_width="50dp"
                android:layout_height="25dp"
                android:layout_alignParentEnd="true"
                android:background="@color/color_f1f1f1"
                android:gravity="center"
                android:text="广告"
                android:textColor="@color/gray_medium"
                android:textSize="12sp"/>

        </RelativeLayout>

        <!-- 广告轮播指示器,暂不实现
        <LinearLayout
            android:id="@+id/adIndicatorLayout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="16dp"
            android:orientation="horizontal"/>
            -->

        <!-- 4. 额度查询卡片 -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardCreditQuery"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="8dp"
            android:clickable="true"
            android:focusable="true">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_gradient_blue_vertical"
                android:padding="20dp">

                <!-- 左侧图标 + 文字组合 -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:id="@+id/ivWalletIcon"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_wallet"
                        app:tint="@color/white" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvCreditTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="额度查询"
                            android:textColor="@color/white"
                            android:textSize="16sp"
                            android:fontFamily="sans-serif-medium" />

                        <TextView
                            android:id="@+id/tvCreditSubtitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="点击查看您的可贷额度"
                            android:textColor="@color/white"
                            android:textSize="13sp"
                            android:alpha="0.9" />

                    </LinearLayout>
                </LinearLayout>

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:src="@drawable/ic_profile_right"
                    app:tint="@color/white"/>

            </RelativeLayout>

        </androidx.cardview.widget.CardView>

        <!-- 5. 热门产品标题 -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="32dp"
            android:layout_marginBottom="0dp">

            <TextView
                android:id="@+id/tvHotProductsTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:text="热门产品"
                android:textColor="@color/text_primary"
                android:textSize="18sp"
                android:textStyle="bold" />

        </RelativeLayout>

        <!-- 6. 产品轮播容器 -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:layout_marginBottom="4dp"
            android:clipChildren="false"
            android:clipToPadding="false">

            <androidx.viewpager2.widget.ViewPager2
                android:id="@+id/viewPagerProducts"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:overScrollMode="never"
                android:clipChildren="false"
                android:clipToPadding="false"/>

        </RelativeLayout>

        <!-- 产品轮播指示器 -->
        <LinearLayout
            android:id="@+id/productIndicatorLayout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="16dp"
            android:orientation="horizontal"/>

        <!-- 7. 探索更多按钮 -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardExploreMore"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:cardCornerRadius="28dp"
            app:cardElevation="0dp"
            android:clickable="true"
            android:focusable="true">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_gradient_blue_horizontal"
                android:gravity="center">

                <TextView
                    android:id="@+id/tvExploreMore"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerInParent="true"
                    android:text="探索更多贷款产品"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    android:fontFamily="sans-serif-medium"/>

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_centerVertical="true"
                    android:layout_toEndOf="@id/tvExploreMore"
                    android:layout_marginStart="4dp"
                    android:src="@drawable/ic_profile_right"
                    app:tint="@color/white"/>

            </RelativeLayout>

            <View
                android:layout_width="0dp"
                android:layout_height="24dp" />

        </androidx.cardview.widget.CardView>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>