<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF8FAFF">

    <!--顶部导航栏-->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/top_leading"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#FF458FFC"
        android:elevation="4dp"
        app:layout_constraintTop_toTopOf="parent"
        app:titleTextColor="@color/white"
        app:titleCentered="true">

        <!--返回按钮-->
        <ImageView
            android:id="@+id/apply_btn_back"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="start|center_vertical"
            android:layout_marginStart="16dp"
            android:src="@drawable/ic_arrow_back_white"
            android:contentDescription="@string/nav_back"/>

        <!--页面标题，贷款产品-->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="贷款产品"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end"/>

    </com.google.android.material.appbar.MaterialToolbar>

    <!--搜索框-->
    <LinearLayout
        android:id="@+id/search_button"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_search_rounded"
        android:elevation="2dp"
        android:paddingStart="16dp"
        android:paddingEnd="0dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@id/top_leading">

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_search"
            android:contentDescription="@string/search" />

        <EditText
            android:id="@+id/etSearch"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@null"
            android:hint="请输入您需要查找的贷款产品名称"
            android:textSize="14sp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_quaternary"
            android:paddingStart="12dp"
            android:inputType="text"
            android:imeOptions="actionSearch" />

        <androidx.appcompat.widget.AppCompatButton
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@color/transparent"
            android:fontFamily="sans-serif-medium"
            android:text="搜索"
            android:textColor="@color/main_blue"
            android:textSize="15sp" />

    </LinearLayout>

    <!-- 筛选容器：包含分类栏和排序栏 -->
    <LinearLayout
        android:id="@+id/filter_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="8dp"
        android:orientation="vertical"
        android:background="@drawable/bg_loan_product_filter_container"
        android:elevation="2dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/search_button">

        <!--产品分类-->
        <LinearLayout
            android:id="@+id/loan_classify"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:orientation="horizontal"
            android:paddingTop="4dp"
            android:paddingBottom="4dp">

            <!--个人消费-->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:text="@string/personal_consumption"
                android:layout_weight="1"
                android:gravity="center"
                android:textSize="16sp"
                android:textColor="@color/loan_sort_text_selector"/>

            <!--农业生产-->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:text="@string/agricultural_production"
                android:layout_weight="1"
                android:gravity="center"
                android:textSize="16sp"
                android:textColor="@color/loan_sort_text_selector"/>

            <!--企业经营-->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:text="@string/business_operation"
                android:layout_weight="1"
                android:gravity="center"
                android:textSize="16sp"
                android:textColor="@color/loan_sort_text_selector"/>

        </LinearLayout>

        <!-- 分类与排序之间的分割线 -->
        <View
            android:id="@+id/category_sort_divider"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#F0F0F0"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp" />

        <!-- 产品排序 -->
        <LinearLayout
            android:id="@+id/loan_sort"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:orientation="horizontal"
            android:paddingTop="4dp"
            android:paddingBottom="4dp">

            <!-- 利率排序 -->
            <LinearLayout
                android:id="@+id/rate_sort"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:id="@+id/tvSortRate"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:text="@string/rate"
                    android:textSize="14sp"
                    android:textColor="#333333"
                    android:gravity="center_vertical"
                    android:layout_marginEnd="8dp"/>

                <ImageView
                    android:id="@+id/ivSortRateAsc"
                    android:layout_width="25dp"
                    android:layout_height="25dp"
                    android:src="@drawable/up_sort"
                    android:layout_gravity="center_vertical"
                    android:layout_marginEnd="4dp"/>

                <ImageView
                    android:id="@+id/ivSortRateDesc"
                    android:layout_width="25dp"
                    android:layout_height="25dp"
                    android:src="@drawable/down_sort"
                    android:layout_gravity="center_vertical"/>
            </LinearLayout>

            <!-- 额度排序 -->
            <LinearLayout
                android:id="@+id/amount_sort"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:id="@+id/tvSortAmount"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:text="@string/amount"
                    android:textSize="14sp"
                    android:textColor="#333333"
                    android:gravity="center_vertical"
                    android:layout_marginEnd="8dp"/>

                <ImageView
                    android:id="@+id/ivSortAmountAsc"
                    android:layout_width="25dp"
                    android:layout_height="25dp"
                    android:src="@drawable/up_sort"
                    android:layout_gravity="center_vertical"
                    android:layout_marginEnd="4dp"/>

                <ImageView
                    android:id="@+id/ivSortAmountDesc"
                    android:layout_width="25dp"
                    android:layout_height="25dp"
                    android:src="@drawable/down_sort"
                    android:layout_gravity="center_vertical"/>
            </LinearLayout>

            <!-- 期限排序 -->
            <LinearLayout
                android:id="@+id/term_sort"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:id="@+id/tvSortTerm"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:text="@string/term"
                    android:textSize="14sp"
                    android:textColor="#333333"
                    android:gravity="center_vertical"
                    android:layout_marginEnd="8dp"/>

                <ImageView
                    android:id="@+id/ivSortTermAsc"
                    android:layout_width="25dp"
                    android:layout_height="25dp"
                    android:src="@drawable/up_sort"
                    android:layout_gravity="center_vertical"
                    android:layout_marginEnd="4dp"/>

                <ImageView
                    android:id="@+id/ivSortTermDesc"
                    android:layout_width="25dp"
                    android:layout_height="25dp"
                    android:src="@drawable/down_sort"
                    android:layout_gravity="center_vertical"/>
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>

    <!-- 产品列表 -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvProducts"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="9dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="24dp"
        android:nestedScrollingEnabled="false"
        app:layout_constraintTop_toBottomOf="@id/filter_container"
        app:layout_constraintBottom_toBottomOf="parent"/>


</androidx.constraintlayout.widget.ConstraintLayout>