<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_product_info_card"
    android:layout_marginVertical="4dp"
    android:layout_marginHorizontal="16dp"
    android:elevation="2dp"
    android:orientation="horizontal">

    <!-- 状态竖线 -->
    <View
        android:id="@+id/status_line"
        android:layout_width="5dp"
        android:layout_height="match_parent"
        android:background="@color/application_status_pending"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"/>

    <!-- 内容容器 -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingVertical="16dp"
        android:paddingEnd="16dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- 1. 贷款名称 (作为定位基准) -->
            <TextView
                android:id="@+id/loan_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="17sp"
                android:textColor="@color/text_primary"
                android:fontFamily="sans-serif-medium" />

            <!-- 2. 申请金额提示 -->
            <TextView
                android:id="@+id/tv_amount_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/loan_name"
                android:layout_marginTop="4dp"
                android:text="@string/application_amount"
                android:textSize="14sp"
                android:textColor="@color/text_tertiary" />

            <!-- 3. 申请金额 (字体放大) -->
            <TextView
                android:id="@+id/loan_amount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/tv_amount_label"
                android:layout_marginTop="2dp"
                android:text=""
                android:textSize="26sp"
                android:textColor="@color/number_amount"
                android:fontFamily="sans-serif-medium" />

            <!-- 4. 状态图标 -->
            <ImageView
                android:id="@+id/status_icon"
                android:layout_width="90dp"
                android:layout_height="90dp"
                android:layout_alignParentEnd="true"
                android:layout_alignTop="@id/loan_name"
                android:src="@drawable/application_status_pending"
                android:scaleType="centerInside" />

        </RelativeLayout>


        <!-- 操作按钮 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- 申请时间标签 -->
            <TextView
                android:id="@+id/tv_apply_time_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/apply_time"
                android:textSize="14sp"
                android:textColor="@color/text_tertiary"
                android:layout_marginBottom="2dp" />

            <!-- 时间和操作按钮 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <!-- 申请时间 (左侧) -->
                <TextView
                    android:id="@+id/application_time"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="14sp"
                    android:textColor="@color/text_tertiary"
                    android:layout_weight="1" />

                <!-- 取消申请按钮 (右侧 - 靠近中间) -->
                <Button
                    android:id="@+id/btn_cancel"
                    android:layout_width="70dp"
                    android:layout_height="35dp"
                    android:text="@string/cancel_application"
                    android:textSize="11sp"
                    android:textColor="#DC2626"
                    android:background="@drawable/bg_button_application_canceled"
                    app:backgroundTint="@null"
                    android:padding="0dp"
                    android:layout_marginStart="10dp"
                    android:layout_marginEnd="8dp"
                    />

                <!-- 查看详情按钮 (右侧 - 最边缘) -->
                <Button
                    android:id="@+id/btn_detail"
                    android:layout_width="70dp"
                    android:layout_height="35dp"
                    android:background="@drawable/bg_button_application_learn_detail"
                    app:backgroundTint="@null"
                    android:padding="0dp"
                    android:text="@string/view_detail"
                    android:textColor="@color/white"
                    android:textSize="11sp" />

            </LinearLayout>

        </LinearLayout>
    </LinearLayout>

</LinearLayout>