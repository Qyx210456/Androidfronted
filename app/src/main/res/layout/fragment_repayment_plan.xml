<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/lightest_blue">

    <!--顶部导航栏 - 使用Material Toolbar并适配状态栏-->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/top_leading"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#FF458FFC"
        android:elevation="4dp"
        app:layout_constraintTop_toTopOf="parent"
        app:titleTextColor="@color/white"
        app:titleCentered="true">

        <!--返回按钮-->
        <ImageView
            android:id="@+id/apply_btn_back"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="start|center_vertical"
            android:layout_marginStart="16dp"
            android:src="@drawable/ic_arrow_back_white"
            android:contentDescription="@string/nav_back" />

        <!--页面标题，还款计划-->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="还款计划"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end"/>

    </com.google.android.material.appbar.MaterialToolbar>

    <LinearLayout
        android:id="@+id/filter_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/white"
        android:paddingVertical="12dp"
        android:paddingHorizontal="16dp"
        app:layout_constraintTop_toBottomOf="@id/top_leading">

        <!-- 第一行：排序 + 状态筛选 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <!-- 1. 左侧：固定的排序按钮 -->
            <LinearLayout
                android:id="@+id/btn_sort"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:clickable="true"
                android:focusable="true"
                android:background="@drawable/bg_repayment_plan_filter_date_range"
                android:paddingStart="12dp"
                android:paddingEnd="12dp">

                <!-- 文字：排序 -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/repayment_plan_sort_term"
                    android:textSize="14sp"
                    android:textColor="@color/number_amount"
                    android:includeFontPadding="false" />

                <!-- 图标：向下箭头 -->
                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_repayment_plan_filter_sort_down_arrow"
                    android:scaleType="centerInside"
                    android:layout_marginStart="8dp"
                    android:contentDescription="@null" />

            </LinearLayout>

            <!-- 2. 排序按钮与状态筛选之间的间距 -->
            <Space
                android:layout_width="10dp"
                android:layout_height="1dp"
                android:layout_marginEnd="8dp" />

            <!-- 3. 右侧：可横向滚动的状态筛选按钮列表 -->
            <HorizontalScrollView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:scrollbars="none"
                android:fadingEdge="none">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- 按钮：全部 -->
                    <Button
                        android:id="@+id/btn_filter_all"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="@string/repayment_plan_filter_all"
                        android:textSize="14sp"
                        android:textColor="@color/loan_application_status_text_filter"
                        android:background="@drawable/bg_application_status_all"
                        app:backgroundTint="@null"
                        android:gravity="center"
                        android:layout_marginEnd="8dp"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp" />

                    <!-- 按钮：已还 -->
                    <Button
                        android:id="@+id/btn_filter_repaid"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="@string/repayment_plan_filter_repaid"
                        android:textSize="14sp"
                        android:textColor="@color/repayment_plan_filter_status_repaid"
                        android:background="@drawable/bg_repayment_plan_filter_status_repaid"
                        app:backgroundTint="@null"
                        android:gravity="center"
                        android:layout_marginEnd="8dp"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp" />

                    <!-- 按钮：未还 -->
                    <Button
                        android:id="@+id/btn_filter_unpaid"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="@string/repayment_plan_filter_unpaid"
                        android:textSize="14sp"
                        android:textColor="@color/repayment_plan_filter_status_unpaid"
                        android:background="@drawable/bg_repayment_plan_filter_status_unpaid"
                        app:backgroundTint="@null"
                        android:gravity="center"
                        android:layout_marginEnd="8dp"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp" />

                    <!-- 按钮：逾期 -->
                    <Button
                        android:id="@+id/btn_filter_overdue"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="@string/repayment_plan_filter_overdue"
                        android:textSize="14sp"
                        android:textColor="@color/repayment_plan_filter_status_overdue"
                        android:background="@drawable/bg_repayment_plan_filter_status_overdue"
                        app:backgroundTint="@null"
                        android:gravity="center"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp" />

                </LinearLayout>
            </HorizontalScrollView>
        </LinearLayout>

        <!-- 第二行：时间范围筛选（下方添加的行） -->
        <LinearLayout
            android:id="@+id/btn_date_range"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:clickable="true"
            android:focusable="true"
            android:background="@drawable/bg_repayment_plan_filter_date_range"
            android:layout_marginTop="8dp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp">

            <!-- 图标：时间 -->
            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_repayment_plan_filter_time"
                android:scaleType="centerInside"
                android:contentDescription="@null" />

            <!-- 文字：不限时间 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="不限时间"
                android:textSize="14sp"
                android:textColor="@color/button_date_range_text"
                android:layout_marginStart="8dp"
                android:includeFontPadding="false" />

        </LinearLayout>

    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/filter_container"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/stats_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_application_record_detail_card"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="8dp"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tv_term_info"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="16sp"
                    android:textColor="@color/white"
                    android:textStyle="bold"
                    android:includeFontPadding="false" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="12dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="horizontal"
                        android:gravity="center">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="已还："
                            android:textSize="14sp"
                            android:textColor="#B3E0FF"
                            android:includeFontPadding="false" />

                        <TextView
                            android:id="@+id/tv_repaid_count"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=""
                            android:textSize="14sp"
                            android:textColor="@color/white"
                            android:includeFontPadding="false" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="horizontal"
                        android:gravity="center">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="未还："
                            android:textSize="14sp"
                            android:textColor="#B3E0FF"
                            android:includeFontPadding="false" />

                        <TextView
                            android:id="@+id/tv_unpaid_count"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=""
                            android:textSize="14sp"
                            android:textColor="@color/white"
                            android:includeFontPadding="false" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="horizontal"
                        android:gravity="center">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="逾期："
                            android:textSize="14sp"
                            android:textColor="#B3E0FF"
                            android:includeFontPadding="false" />

                        <TextView
                            android:id="@+id/tv_overdue_count"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=""
                            android:textSize="14sp"
                            android:textColor="@color/white"
                            android:includeFontPadding="false" />
                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_repayment_plan"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="16dp"
                android:nestedScrollingEnabled="false"
                android:clipToPadding="false"
                tools:listitem="@layout/item_repayment_plan" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
