<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_product_info_card"
    android:layout_marginVertical="8dp"
    android:layout_marginHorizontal="16dp"
    android:elevation="2dp">

    <!-- 头部：图标+贷款产品名称+状态标签 -->
    <LinearLayout
        android:id="@+id/header_container"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="16dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <!-- 产品图标 -->
        <ImageView
            android:id="@+id/iv_product_icon"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:src="@drawable/ic_item_product_sort"/>

        <!-- 产品名称 -->
        <TextView
            android:id="@+id/tv_product_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="消费备用金"
            android:textSize="18sp"
            android:textColor="#231917"
            android:textStyle="bold"/>

        <!-- 状态标签 -->
        <LinearLayout
            android:id="@+id/status_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_loan_order_corner_status_normal"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="12dp"
            android:paddingVertical="6dp">

            <!-- 状态图标（已结清时显示对勾，已逾期时显示警告） -->
            <ImageView
                android:id="@+id/iv_status_icon"
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@drawable/ic_loan_order_tick_cleared"
                android:visibility="gone"/>

            <!-- 状态文本 -->
            <TextView
                android:id="@+id/tv_order_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:text="已还 4/12 期"
                android:textSize="12sp"
                android:textColor="@color/order_status_normal_text"/>

        </LinearLayout>

    </LinearLayout>

    <!-- 贷款金额 -->
    <LinearLayout
        android:id="@+id/amount_container"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="16dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/header_container">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="贷款金额："
            android:textSize="14sp"
            android:textColor="#85736E"/>

        <TextView
            android:id="@+id/tv_loan_amount_value"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:text="¥20,000"
            android:textSize="26sp"
            android:textColor="#4EACFB"
            android:textStyle="bold"/>

    </LinearLayout>

    <!-- 下次还款时间/结清日期 -->
    <LinearLayout
        android:id="@+id/time_container"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="16dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/bg_loan_order_time_background"
        android:paddingHorizontal="12dp"
        android:paddingVertical="12dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/amount_container">

        <!-- 日历图标 -->
        <ImageView
            android:id="@+id/iv_time_icon"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_loan_order_date_upcoming"/>

        <!-- 时间标签 -->
        <TextView
            android:id="@+id/tv_time_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="下次还款日期："
            android:textSize="16sp"
            android:textColor="#85736E"/>

        <!-- 时间值 -->
        <TextView
            android:id="@+id/tv_time_value"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:text="2026-06-20 (3天后)"
            android:textSize="16sp"
            android:textColor="#2196F3"/>

    </LinearLayout>

    <!-- 订单编号 -->
    <LinearLayout
        android:id="@+id/order_number_container"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="16dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/time_container">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="订单编号："
            android:textSize="14sp"
            android:textColor="#85736E"/>

        <TextView
            android:id="@+id/tv_order_number_value"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:text="LN20260519233"
            android:textSize="14sp"
            android:textColor="#53433F"/>

    </LinearLayout>

    <!-- 订单生成时间 -->
    <LinearLayout
        android:id="@+id/order_time_container"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="16dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/order_number_container"
        app:layout_constraintBottom_toBottomOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="订单生成时间："
            android:textSize="14sp"
            android:textColor="#85736E"/>

        <TextView
            android:id="@+id/tv_order_time_value"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:text="2026-05-19 23:01:57"
            android:textSize="14sp"
            android:textColor="#53433F"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>