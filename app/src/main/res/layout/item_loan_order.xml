<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_product_info_card"
    android:layout_marginVertical="4dp"
    android:layout_marginHorizontal="16dp"
    android:elevation="2dp"
    android:orientation="vertical">

    <!-- 订单编号和状态 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="16dp"
        android:paddingTop="16dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- 订单编号容器 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- 订单编号标签 -->
            <TextView
                android:id="@+id/tv_order_number_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="订单编号"
                android:textSize="14sp"
                android:textColor="@color/text_secondary" />

            <!-- 订单编号值 -->
            <TextView
                android:id="@+id/tv_order_number_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text=""
                android:textSize="14sp"
                android:textColor="@color/text_primary" />

        </LinearLayout>

        <!-- 状态角标 -->
        <TextView
            android:id="@+id/tv_order_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:background="@drawable/bg_loan_order_corner_status_normal"
            android:text="正常"
            android:textSize="14sp"
            android:textColor="@color/order_status_normal_text"
            android:paddingHorizontal="16dp"
            android:paddingVertical="6dp" />

    </LinearLayout>

    <!-- 贷款金额 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:paddingHorizontal="16dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- 贷款金额标签 -->
        <TextView
            android:id="@+id/tv_loan_amount_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="贷款金额"
            android:textSize="14sp"
            android:textColor="@color/text_secondary" />

        <!-- 贷款金额值 -->
            <TextView
                android:id="@+id/tv_loan_amount_value"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text=""
                android:textSize="26sp"
                android:textColor="@color/number_amount"
                android:fontFamily="sans-serif-medium" />

    </LinearLayout>

    <!-- 分隔线 -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/text_tertiary"
        android:alpha="0.2"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="16dp" />

    <!-- 订单生成时间和查看详情按钮 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp"
        android:paddingHorizontal="16dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- 订单生成时间 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- 时间标签 -->
            <TextView
                android:id="@+id/tv_order_time_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="订单生成时间"
                android:textSize="14sp"
                android:textColor="@color/text_tertiary" />

            <!-- 时间值 -->
            <TextView
                android:id="@+id/tv_order_time_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text=""
                android:textSize="14sp"
                android:textColor="@color/text_tertiary" />

        </LinearLayout>

        <!-- 查看详情按钮 -->
        <Button
            android:id="@+id/btn_view_detail"
            android:layout_width="70dp"
            android:layout_height="35dp"
            android:layout_marginStart="16dp"
            android:background="@drawable/bg_button_application_learn_detail"
            app:backgroundTint="@null"
            android:padding="0dp"
            android:text="@string/view_detail"
            android:textColor="@color/white"
            android:textSize="11sp" />

    </LinearLayout>

</LinearLayout>