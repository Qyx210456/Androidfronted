<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/lightest_blue">

    <!--顶部导航栏 - 使用Material Toolbar并适配状态栏-->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/top_leading"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#FF458FFC"
        android:elevation="4dp"
        app:layout_constraintTop_toTopOf="parent"
        app:titleTextColor="@color/white"
        app:titleCentered="true">

        <!--返回按钮-->
        <ImageView
            android:id="@+id/apply_btn_back"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="start|center_vertical"
            android:layout_marginStart="16dp"
            android:src="@drawable/ic_arrow_back_white"
            android:contentDescription="@string/nav_back" />

        <!--页面标题，不动产证明-->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="@string/property_cert"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end"/>

    </com.google.android.material.appbar.MaterialToolbar>

    <!-- 未认证状态容器 -->
    <LinearLayout
        android:id="@+id/container_not_certified"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="32dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/top_leading"
        app:layout_constraintBottom_toBottomOf="parent">

        <ImageView
            android:id="@+id/iv_bank_card_icon"
            android:layout_width="170dp"
            android:layout_height="150dp"
            android:layout_marginTop="60dp"
            android:layout_marginBottom="24dp"
            android:src="@drawable/no_bank_card"
            tools:src="@drawable/no_bank_card" />

        <TextView
            android:id="@+id/tv_no_bank_card_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/no_info_property"
            android:textColor="@color/text_secondary"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btn_property_upload"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="50dp"
            android:background="@drawable/bg_gradient_blue_horizontal"
            app:backgroundTint="@null"
            android:text="@string/upload_property"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- 上传中状态容器 -->
    <ScrollView
        android:id="@+id/container_uploading"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/top_leading"
        app:layout_constraintBottom_toTopOf="@id/btn_confirm_property_upload"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:layout_marginTop="16dp"
            android:paddingEnd="32dp"
            android:paddingStart="32dp"
            android:paddingBottom="16dp">

            <!-- 类型选择 -->
            <LinearLayout
                android:id="@+id/ll_type_selection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/upload_material_type"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp"
                    android:layout_marginBottom="8dp"/>

                <LinearLayout
                    android:id="@+id/ll_upload_type"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_id_card"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:id="@+id/tv_upload_type"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:gravity="center_vertical|start"
                        android:text="请选择上传资料类型"
                        android:textColor="@color/text_quaternary"
                        android:textSize="13sp"/>

                    <ImageView
                        android:id="@+id/iv_dropdown_arrow"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_arrow_drop_down"
                        app:tint="#FF458FFC" />

                </LinearLayout>

            </LinearLayout>

            <!-- 上传图标 -->
            <FrameLayout
                android:id="@+id/ll_upload_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_info_upload_picture"
                android:clipToPadding="false"
                android:elevation="2dp"
                android:padding="16dp">

                <ImageView
                    android:id="@+id/iv_corner_left_up"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="top|start"
                    android:src="@drawable/ic_profile_menu_info_upload_picture_left_up_arrow" />

                <ImageView
                    android:id="@+id/iv_corner_right_up"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="top|end"
                    android:src="@drawable/ic_profile_menu_info_upload_picture_right_up_arrow" />

                <ImageView
                    android:id="@+id/iv_corner_left_down"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="bottom|start"
                    android:src="@drawable/ic_profile_menu_info_upload_picture_left_down_arrow" />

                <ImageView
                    android:id="@+id/iv_corner_right_down"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="bottom|end"
                    android:src="@drawable/ic_profile_menu_info_upload_picture_right_down_arrow" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center_horizontal"
                    android:layout_margin="20dp">

                    <ImageView
                        android:id="@+id/iv_upload_icon"
                        android:layout_width="260dp"
                        android:layout_height="140dp"
                        android:src="@drawable/ic_profile_menu_info_upload_picture"
                        android:clickable="true"
                        android:focusable="true"/>

                    <TextView
                        android:id="@+id/tv_upload_hint"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/click_upload_image"
                        android:textColor="@color/number_amount"
                        android:textStyle="bold"
                        android:textSize="15sp"
                        android:layout_marginTop="8dp"/>

                </LinearLayout>

            </FrameLayout>

        </LinearLayout>
    </ScrollView>

    <!-- "确认上传"按钮（固定底部） -->
    <Button
        android:id="@+id/btn_confirm_property_upload"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginHorizontal="32dp"
        android:layout_marginBottom="32dp"
        android:layout_marginTop="16dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        android:background="@drawable/bg_gradient_blue_horizontal"
        app:backgroundTint="@null"
        android:text="@string/confirm_upload"
        android:textColor="@color/white"
        android:textSize="16sp"
        android:textStyle="bold" />

    <!-- 已认证状态容器 -->
    <LinearLayout
        android:id="@+id/container_certified"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/top_leading"
        app:layout_constraintBottom_toTopOf="@id/btn_add_property">

        <!-- 筛选和删除按钮行 -->
        <LinearLayout
            android:id="@+id/ll_filter_row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="16dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- 筛选组件 -->
            <LinearLayout
                android:id="@+id/ll_filter"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:background="@drawable/bg_id_card"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="筛选："
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp"
                    android:layout_marginEnd="8dp"
                    android:gravity="center_vertical"/>

                <Spinner
                    android:id="@+id/spinner_filter"
                    style="@style/CustomSpinnerStyle"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@android:color/transparent"
                    android:paddingEnd="0dp"/>

                <ImageView
                    android:id="@+id/iv_filter_arrow"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_arrow_drop_down"
                    app:tint="#FF458FFC" />

            </LinearLayout>

            <!-- 删除按钮 -->
            <Button
                android:id="@+id/btn_delete"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:paddingHorizontal="16dp"
                android:background="@drawable/bg_gradient_blue_horizontal"
                app:backgroundTint="@null"
                android:text="管理"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:layout_marginStart="16dp"/>

        </LinearLayout>

        <!-- 已上传图片列表 -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_uploaded_certificates"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginTop="16dp"
            app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
            app:spanCount="2"
            tools:listitem="@layout/item_uploaded_certificate"/>

    </LinearLayout>

    <!-- 添加不动产证明按钮 -->
    <Button
        android:id="@+id/btn_add_property"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginHorizontal="32dp"
        android:layout_marginBottom="32dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        android:background="@drawable/bg_gradient_blue_horizontal"
        app:backgroundTint="@null"
        android:text="@string/upload_property"
        android:textColor="@color/white"
        android:textSize="16sp"
        android:textStyle="bold" />

</androidx.constraintlayout.widget.ConstraintLayout>
