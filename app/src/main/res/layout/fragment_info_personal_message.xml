<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/lightest_blue">

    <!--顶部导航栏 - 使用Material Toolbar并适配状态栏-->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/top_leading"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#FF458FFC"
        android:elevation="4dp"
        app:layout_constraintTop_toTopOf="parent"
        app:titleTextColor="@color/white"
        app:titleCentered="true">

        <!--返回按钮-->
        <ImageView
            android:id="@+id/apply_btn_back"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="start|center_vertical"
            android:layout_marginStart="16dp"
            android:src="@drawable/ic_arrow_back_white"
            android:contentDescription="@string/nav_back" />

        <!--页面标题，个人信息认证-->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="@string/personal_info"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end"/>

    </com.google.android.material.appbar.MaterialToolbar>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="32dp"
        app:layout_constraintTop_toBottomOf="@id/top_leading">

        <LinearLayout
            android:id="@+id/banner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="0dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="10dp">

                <!-- 标题 -->
                <TextView
                    android:id="@+id/tv_topic"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="0dp"
                    android:layout_marginTop="0dp"
                    android:text="@string/info_banner_one"
                    android:textColor="@color/number_amount"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="0dp"
                    android:layout_marginTop="9dp"
                    android:text="@string/info_banner_two"
                    android:textColor="@color/number_amount"
                    android:textSize="18sp"
                    android:fontFamily="sans-serif-medium"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tv_topic"/>


            </LinearLayout>

            <!--一个图标（待上传）-->
            <ImageView
                android:layout_width="200dp"
                android:layout_height="120dp"
                android:src="@drawable/personal_info_head_illustration"
                android:layout_marginEnd="0dp"/>

        </LinearLayout>

        <!-- 1. 实名认证 -->
        <LinearLayout
            android:id="@+id/id_info"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginTop="32dp"
            android:background="@color/white"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            app:layout_constraintTop_toBottomOf="@id/banner">

            <!--实名认证图标-->
            <ImageView
                android:layout_width="25dp"
                android:layout_height="25dp"
                android:contentDescription="@string/menu_personal_info_auth"
                android:src="@drawable/ic_id_info" />

            <!--实名认证text-->
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_weight="5"
                android:text="@string/id_info"
                android:textColor="@color/gray_dark_100"
                android:textSize="14sp" />

            <!--认证状态-->
            <TextView
                android:id="@+id/tv_id_status"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="20dp"
                android:layout_weight="1"
                android:text="@string/no_info"
                android:textColor="@color/no_info"
                android:textSize="13sp"/>

            <!--查看详情右箭头-->
            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:contentDescription="@string/go_detail"
                android:src="@drawable/ic_profile_right" />
        </LinearLayout>

        <!-- 2.工作证明 -->
        <LinearLayout
            android:id="@+id/job_info"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginTop="8dp"
            android:background="@color/white"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="10dp"
            android:paddingEnd="10dp">

            <!--工作证明图标-->
            <ImageView
                android:layout_width="25dp"
                android:layout_height="25dp"
                android:contentDescription="@string/menu_personal_info_auth"
                android:src="@drawable/ic_job_info" />

            <!--工作证明text-->
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_weight="5"
                android:text="@string/job_info"
                android:textColor="@color/gray_dark_100"
                android:textSize="14sp" />

            <!--认证状态-->
            <TextView
                android:id="@+id/tv_job_status"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="20dp"
                android:layout_weight="1"
                android:text="@string/no_info"
                android:textColor="@color/no_info"
                android:textSize="13sp"/>

            <!--查看详情右箭头-->
            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:contentDescription="@string/go_detail"
                android:src="@drawable/ic_profile_right" />
        </LinearLayout>

        <!-- 3.房产证明 -->

        <!-- 4.第三方证明 -->
        <LinearLayout
            android:id="@+id/house_info"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginTop="8dp"
            android:background="@color/white"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="10dp"
            android:paddingEnd="10dp">

            <!--房产证明图标-->
            <ImageView
                android:layout_width="25dp"
                android:layout_height="25dp"
                android:contentDescription="@string/menu_personal_info_auth"
                android:src="@drawable/ic_house_info" />

            <!--房产证明text-->
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="20dp"
                    android:layout_weight="5"
                    android:text="@string/property_cert"
                    android:textColor="@color/gray_dark_100"
                    android:textSize="14sp" />

            <!--认证状态-->
            <TextView
                android:id="@+id/tv_house_status"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="20dp"
                android:layout_weight="1"
                android:text="@string/no_info"
                android:textColor="@color/no_info"
                android:textSize="13sp" />

            <!--查看详情右箭头-->
            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:contentDescription="@string/go_detail"
                android:src="@drawable/ic_profile_right" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/other_info"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginTop="8dp"
            android:background="@color/white"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="10dp"
            android:paddingEnd="10dp">

            <!--第三方证明图标-->
            <ImageView
                android:layout_width="25dp"
                android:layout_height="25dp"
                android:contentDescription="@string/menu_personal_info_auth"
                android:src="@drawable/ic_other_info" />

            <!--第三方证明text-->
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_weight="5"
                android:text="@string/other_info"
                android:textColor="@color/gray_dark_100"
                android:textSize="14sp" />

            <!--认证状态-->
            <TextView
                android:id="@+id/tv_other_status"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="20dp"
                android:layout_weight="1"
                android:text="@string/no_info"
                android:textColor="@color/no_info"
                android:textSize="13sp"/>

            <!--查看详情右箭头-->
            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:contentDescription="@string/go_detail"
                android:src="@drawable/ic_profile_right" />

        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>