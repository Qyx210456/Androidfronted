<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- 手机号输入框 -->
    <EditText
        android:id="@+id/etPhone"
        android:layout_width="0dp"
        android:layout_height="52dp"
        android:layout_marginStart="20dp"
        android:layout_marginTop="22dp"
        android:layout_marginEnd="20dp"
        android:hint="@string/hint_phone_number"
        android:textColor="@color/gray_dark_73"
        android:textSize="15sp"
        android:fontFamily="sans-serif"
        android:inputType="phone"
        android:background="@drawable/edittext_bg"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- 验证码输入区域 -->
    <LinearLayout
        android:id="@+id/verifyCodeLayout"
        android:layout_width="0dp"
        android:layout_height="52dp"
        android:layout_marginStart="20dp"
        android:layout_marginTop="22dp"
        android:layout_marginEnd="20dp"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@id/etPhone"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <EditText
            android:id="@+id/etVerifyCode"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@drawable/edittext_bg"
            android:fontFamily="sans-serif"
            android:hint="@string/hint_verification_code"
            android:inputType="number"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:textColor="@color/gray_dark_73"
            android:textSize="15sp"
            tools:layout_editor_absoluteX="-1dp"
            tools:layout_editor_absoluteY="-16dp" />

        <Button
            android:id="@+id/btnGetVerifyCode"
            android:layout_width="120dp"
            android:layout_height="match_parent"
            android:layout_marginStart="12dp"
            android:text="@string/btn_get_verification_code"
            android:textColor="#165DFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium"
            android:backgroundTint="#FFFFFF"
            android:backgroundTintMode="src_over"
            android:stateListAnimator="@null" />

    </LinearLayout>

    <!-- 登录按钮 -->
    <Button
        android:id="@+id/btnLogin"
        android:layout_width="0dp"
        android:layout_height="52dp"
        android:layout_marginStart="20dp"
        android:layout_marginTop="30dp"
        android:layout_marginEnd="20dp"
        android:text="@string/btn_login"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textStyle="bold"
        android:fontFamily="sans-serif-medium"
        android:background="@drawable/login_button"
        android:stateListAnimator="@null"
        app:layout_constraintTop_toBottomOf="@id/verifyCodeLayout"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- 注册链接 -->
    <LinearLayout
        android:id="@+id/registerLink"
        android:layout_width="wrap_content"
        android:layout_height="24dp"
        android:layout_marginStart="20dp"
        android:layout_marginTop="22dp"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@id/btnLogin"
        app:layout_constraintStart_toStartOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/text_no_account"
            android:textColor="@color/gray_dark_80"
            android:textSize="14sp"
            android:fontFamily="sans-serif" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/text_no_accountA"
            android:textColor="#165DFF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium" />

    </LinearLayout>

    <!-- 协议同意选项 -->
    <CheckBox
        android:id="@+id/cbAgreement"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:layout_marginStart="20dp"
        android:layout_marginTop="221dp"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="56dp"
        android:text="@string/text_agree_terms"
        android:textColor="#000000"
        android:textSize="13sp"
        android:fontFamily="sans-serif-medium"
        android:paddingStart="30dp"
        android:paddingEnd="0dp"
        android:gravity="center_vertical"
        app:layout_constraintTop_toBottomOf="@id/registerLink"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>



