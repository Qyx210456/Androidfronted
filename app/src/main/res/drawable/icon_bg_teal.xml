<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 渐变背景 -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="@color/func_teal_light"
                android:endColor="@color/color_c7eaff"
                android:angle="135" />
            <corners android:radius="12dp" />
            <size
                android:width="48dp"
                android:height="48dp" />
        </shape>
    </item>

    <!-- 角点装饰 -->
    <item
        android:width="6dp"
        android:height="6dp"
        android:gravity="top|left">
        <rotate android:fromDegrees="45">
            <shape android:shape="rectangle">
                <solid android:color="@color/func_teal" />
            </shape>
        </rotate>
    </item>
</layer-list>