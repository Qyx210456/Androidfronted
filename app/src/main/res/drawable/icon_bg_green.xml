<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 圆形浅绿色背景 -->
    <item>
        <shape android:shape="oval">
            <solid android:color="@color/func_green_light" />
            <size
                android:width="48dp"
                android:height="48dp" />
        </shape>
    </item>

    <!-- 外环 -->
    <item>
        <shape android:shape="oval">
            <stroke
                android:width="2dp"
                android:color="@color/func_green" />
            <size
                android:width="48dp"
                android:height="48dp" />
        </shape>
    </item>
</layer-list>