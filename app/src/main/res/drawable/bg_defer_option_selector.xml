<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_selected="true">
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="@color/defer_glow_blue" />
                    <corners android:radius="20dp" />
                </shape>
            </item>
            <item
                android:bottom="3dp"
                android:left="3dp"
                android:right="3dp"
                android:top="3dp">
                <shape android:shape="rectangle">
                    <solid android:color="@color/defer_option_selected_bg" />
                    <stroke
                        android:width="2dp"
                        android:color="@color/defer_primary_blue" />
                    <corners android:radius="18dp" />
                </shape>
            </item>
        </layer-list>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/defer_option_unselected_bg" />
            <stroke
                android:width="1dp"
                android:color="@color/defer_border_gray" />
            <corners android:radius="20dp" />
        </shape>
    </item>
</selector>
