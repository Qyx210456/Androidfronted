<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 选中状态 - 主蓝色边框 -->
    <item android:state_checked="true">
        <layer-list>
            <!-- 阴影层 -->
            <item>
                <shape android:shape="rectangle">
                    <corners android:radius="12dp" />
                    <solid android:color="#20000000" />
                    <padding
                        android:top="1dp"
                        android:bottom="3dp"
                        android:left="1dp"
                        android:right="3dp" />
                </shape>
            </item>
            <!-- 卡片内容层 -->
            <item android:top="1dp" android:bottom="2dp" android:left="1dp" android:right="2dp">
                <shape android:shape="rectangle">
                    <solid android:color="@color/notification_blue" /> <!-- #FFF0F7FF -->
                    <corners android:radius="12dp" />
                    <stroke
                        android:width="2dp"
                        android:color="@color/main_blue" /> <!-- #FF2D7FF9 -->
                </shape>
            </item>
        </layer-list>
    </item>

    <!-- 未选中状态 - 普通阴影卡片 -->
    <item>
        <layer-list>
            <!-- 阴影层 -->
            <item>
                <shape android:shape="rectangle">
                    <corners android:radius="12dp" />
                    <solid android:color="#0A000000" />
                    <padding
                        android:top="1dp"
                        android:bottom="2dp"
                        android:left="1dp"
                        android:right="2dp" />
                </shape>
            </item>
            <!-- 卡片内容层 -->
            <item android:bottom="1dp" android:right="1dp">
                <shape android:shape="rectangle">
                    <solid android:color="@color/notification_blue" /> <!-- #FFF0F7FF -->
                    <corners android:radius="12dp" />
                    <stroke
                        android:width="1dp"
                        android:color="@color/border_regular" /> <!-- #FFE6EAF2 -->
                </shape>
            </item>
        </layer-list>
    </item>
</selector>