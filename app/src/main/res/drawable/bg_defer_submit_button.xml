<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/defer_glow_blue" />
            <corners android:radius="40dp" />
            <padding
                android:bottom="6dp"
                android:left="2dp"
                android:right="2dp"
                android:top="6dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="0"
                android:endColor="#2D7AD9"
                android:startColor="@color/defer_primary_blue"
                android:type="linear" />
            <corners android:radius="40dp" />
        </shape>
    </item>
</layer-list>
